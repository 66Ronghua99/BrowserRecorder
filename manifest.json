{
  "manifest_version": 3,
  "name": "Camera Overlay",
  "version": "1.0.0",
  "description": "在任意网页上显示摄像头实时画面悬浮窗",
  "permissions": [
    "camera",
    "activeTab",
    "contentSettings",
    "storage",
    "tabs",
    "tabCapture",
    "desktopCapture",
    "microphone",
    "windows"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.svg",
      "48": "icons/icon48.svg",
      "128": "icons/icon128.svg"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["style.css"],
      "run_at": "document_end"
    }
  ],
  "icons": {
    "16": "icons/icon16.svg",
    "48": "icons/icon48.svg",
    "128": "icons/icon128.svg"
  }
}
